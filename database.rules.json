{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": true,
      "$uid": {
        ".write": true,
        ".validate": "newData.hasChildren() && $uid.length <= 64"
      }
    },

    "rooms": {
      ".read": true,
      ".write": true
    },

    "$room": {
      ".read": "$room.beginsWith('room_')",
      ".write": "$room.beginsWith('room_')",
      ".validate": "$room.length <= 128"
    }
  }
}
